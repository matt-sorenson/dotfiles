#!/usr/bin/env zsh
#compdef jwt-print

function() {
    emulate -L zsh
    set -uo pipefail
    setopt err_return

    local _usage="Usage: jwt-print <jwt>

Pretty prints a JWT (JSON Web Token)

Options:
    -h, --help    Show this help message and exit"

    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)
                print "${_usage}"
                return 0
            *)
                print-header -e "Unknown argument: ${arg}"
                print "${_usage}"
                return 1
        esac
        shift
    done

    if ! command -v jq > /dev/null; then
        print-header -e "ERROR: jq not found. Please install jq to use this script."
        return 1
    fi

    local jwt="${1:-}"
    if [[ -z "${jwt}" ]]; then
        if ! command -v pbpaste > /dev/null; then
            print-header -e "ERROR: pbpaste not found. Must pass a JWT as an argument."
            print "${_usage}"
            return 1
        fi
        jwt=$(pbpaste)
    fi

    local header="$(   print "${jwt}" | jq -R 'split(".") | .[0] | @base64d | fromjson')" 2> /dev/null
    local payload="$(  print "${jwt}" | jq -R 'split(".") | .[1] | @base64d | fromjson')" 2> /dev/null
    local issued_at="$(print "${jwt}" | jq -R 'split(".") | .[1] | @base64d | fromjson | .iat | todate')" 2> /dev/null
    local expire_at="$(print "${jwt}" | jq -R 'split(".") | .[1] | @base64d | fromjson | .exp | todate')" 2> /dev/null
    local sig="$(      print "${jwt}" | jq -R 'split(".") | .[2]')" 2> /dev/null

    if [[ -z "${expire_at}" ]]; then
        expire_at="[[Does not expire]]"
    fi

    local errors=()

    if [[ -z "${header}" ]]; then
        errors+=("Header is empty or invalid.")
    fi
    if [[ -z "${payload}" ]]; then
        errors+=("Payload is empty or invalid.")
    fi
    if [[ -z "${issued_at}" ]]; then
        errors+=("Issued at is empty or invalid.")
    fi
    if [[ -z "${sig}" || "${sig}" == 'null' ]]; then
        print-header -w "WARNING: Signature is empty or invalid. This may be a non-signed JWT."
    fi

    if (( ${#errors[@]} > 0 )); then
        print-header -e "ERROR: JWT parsing failed: '${jwt}'"
        local message=""
        local error
        for error in "${errors[@]}"; do
            message="${message}- ${error}\n"
        done
        print "${message}"
        return 1
    fi

    print-header green "JWT> '${jwt}'"
    print "Header:
    ${header}
Payload:
    ${payload}
Issued at: ${issued_at}
Expire at: ${expire_at}
Sig: ${sig}"

    return 0
} "$@"
