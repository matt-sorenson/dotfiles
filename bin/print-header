#!/bin/sh

# Print usage information
print_header_usage() {
    printf '%s\n' "Usage: print-header [-h|--help] <color> <message>" \
                   "Options:" \
                   "  -h, --help          Show this help message and exit" \
                   "  <color>             The color of the header (e.g., red, green, blue)" \
                   "  <message>           The message to display in the header"

    exit "$1"
}

# Map color names to ANSI escape codes
case_insensitive_color() {
    # Normalize to lowercase
    color=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')

    case "$color" in
        black)  printf '\033[1;30m' ;;
        red)    printf '\033[1;31m' ;;
        green)  printf '\033[1;32m' ;;
        yellow) printf '\033[1;33m' ;;
        blue)   printf '\033[1;34m' ;;
        magenta)printf '\033[1;35m' ;;
        cyan)   printf '\033[1;36m' ;;
        white)  printf '\033[1;37m' ;;
        *)      printf '' ;;  # Unknown color: no coloring
    esac
}

# Generate a line of '=' characters of given length
make_header_line() {
    # printf '%*s' pads spaces; tr converts spaces to '='
    printf '%*s' "$1" '' | tr ' ' '='
}

# --- main script starts here ---

# Parse options
while [ $# -gt 0 ]; do
    case "$1" in
        -h|--help)
            print_header_usage 0
            ;;
        --)
            shift
            break
            ;;
        -*)
            echo "Unknown option: $1" >&2
            print_header_usage 1
            ;;
        *)
            break
            ;;
    esac
done

# First argument is the color name
color_code=$(case_insensitive_color "$1")
# Shift off the color argument
shift
# Reset code
reset_code=$(printf '\033[0m')
# Build header line of width 80
header_line=$(make_header_line 80)
# Remaining arguments form the message
message=$*

# Print the colored header, message, and footer
# Using printf to handle newlines reliably
printf '%s%s\n%s %s\n%s%s\n' "$color_code" "$header_line" "= " "$message" "$header_line" "$reset_code"

exit 0
